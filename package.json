{
  "name": "slice1-funding-scanner",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && esbuild dashboard/main.ts --bundle --outfile=dashboard/main.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard-watch": "esbuild dashboard/main.ts --bundle --outfile=dashboard/main.js --watch=forever",
    "utest": "vitest run --config vitest.config.ts",
    "itest": "vitest run --config vitest.integration.config.ts --reporter=verbose"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
